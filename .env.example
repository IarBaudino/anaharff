# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MercadoPago - Crear app en https://www.mercadopago.com.ar/developers
MERCADOPAGO_ACCESS_TOKEN=

# Cloudinary - https://cloudinary.com → Dashboard → API Keys (credenciales)
# El cloud name también está en la parte superior del dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Opcional: subcarpeta para uploads del panel (default anaharff/tienda)
CLOUDINARY_UPLOAD_FOLDER=anaharff/tienda

# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (JSON completo en una línea, para API routes y webhooks)
# Firebase console → Project settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_KEY=

# Tienda: por defecto habilitada; poné "false" para modo próximamente
NEXT_PUBLIC_TIENDA_ENABLED=true

# Resend (opcional, para formulario de contacto)
RESEND_API_KEY=
