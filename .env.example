# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MercadoPago - Crear app en https://www.mercadopago.com.ar/developers
MERCADOPAGO_ACCESS_TOKEN=

# Supabase Storage (imágenes del panel / sitio)
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo servidor / scripts (nunca exponer en el cliente)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=images
SUPABASE_STORAGE_PREFIX=anaharff

# Firebase (auth admin + Firestore contenido del sitio)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (JSON completo en una línea, para API routes y webhooks)
# Firebase console → Project settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_KEY=

# Tienda: por defecto habilitada; poné "false" para modo próximamente
NEXT_PUBLIC_TIENDA_ENABLED=true

# Sentry (opcional — monitoreo de errores en producción)
# Crear proyecto en https://sentry.io y pegar el DSN
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Gmail SMTP (contacto, bienvenida, confirmación de compras)
# Google → Seguridad → Verificación en 2 pasos → Contraseñas de aplicaciones
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hola@gmail.com
SMTP_PASS=
EMAIL_FROM=Ana Harff <hola@gmail.com>
# Bandeja de Ana (contacto + avisos de venta; puede ser el mismo Gmail)
ADMIN_EMAIL=
